# Copy this file to .env for local deployment.
# Keep .env out of Git. It may contain local paths and future secrets.

KEUMJM_HOST=0.0.0.0
KEUMJM_PORT=8515

# lan: allow localhost, private IPs, and KEUMJM_ALLOWED_CIDRS only.
# internet: allow all client IPs. Use only behind HTTPS/auth/reverse proxy.
KEUMJM_ACCESS_MODE=lan
KEUMJM_ALLOWED_CIDRS=

# Keep docs on for LAN testing. Turn off before public internet exposure.
KEUMJM_ENABLE_DOCS=true

# Optional runtime data locations.
KEUMJ_SP500_DB_DIR=data/sp500_shared_db
KEUMJ_PORTFOLIO_DB_DIR=data/portfolio
